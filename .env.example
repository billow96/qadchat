# QADChat 环境变量配置示例
# 复制此文件为 .env 并填入实际的配置值

# ================================
# 使用说明
# ================================
# 1. 推荐使用 ACCESS_GROUPS_FILE / ACCESS_GROUPS_DIR 指向持久化目录中的分组配置文件
# 2. 配置文件中的 accessCode 优先于旧 ACCESS_CODE 环境变量
# 3. 当配置文件不存在、或未命中任何分组密码时，仍会回退到旧的 ACCESS_CODE + *_API_KEY + *_BASE_URL 逻辑
# 4. 用户在前端配置的 API 密钥仍可覆盖本地请求头，但服务器分组配置默认走服务端转发
# 5. 配置文件模式下，用户输入访问码后会自动加载该分组默认模型、模型列表和 MCP
# 6. Docker 部署时建议挂载 /app/data，并把 access-groups.json 放入其中

# ================================
# 分组配置文件（推荐）
# ================================
# 方式1：直接指定完整文件路径
# ACCESS_GROUPS_FILE=/app/data/access-groups.json
#
# 方式2：指定目录，系统会读取 <目录>/access-groups.json
ACCESS_GROUPS_DIR=/app/data

# 会话签名密钥（强烈建议生产环境设置）
ACCESS_SESSION_SECRET=replace-with-a-long-random-secret

# ================================
# 旧版单密码模式（向后兼容）
# ================================
# 当未使用分组配置文件时，可继续使用以下环境变量
ACCESS_CODE=your-access-code

# ================================
# OpenAI 配置
# ================================
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com

# ================================
# Google (Gemini) 配置
# ================================
GOOGLE_API_KEY=your-google-api-key
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com

# ================================
# Anthropic (Claude) 配置
# ================================
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_BASE_URL=https://api.anthropic.com

# ================================
# ByteDance (豆包) 配置
# ================================
BYTEDANCE_API_KEY=your-bytedance-api-key
BYTEDANCE_BASE_URL=https://ark.cn-beijing.volces.com

# ================================
# Alibaba (通义千问) 配置
# ================================
ALIBABA_API_KEY=your-alibaba-api-key
ALIBABA_BASE_URL=https://dashscope.aliyuncs.com

# ================================
# Moonshot (月之暗面) 配置
# ================================
MOONSHOT_API_KEY=your-moonshot-api-key
MOONSHOT_BASE_URL=https://api.moonshot.cn

# ================================
# DeepSeek 配置
# ================================
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ================================
# XAI (Grok) 配置
# ================================
XAI_API_KEY=your-xai-api-key
XAI_BASE_URL=https://api.x.ai

# ================================
# SiliconFlow 配置
# ================================
SILICONFLOW_API_KEY=your-siliconflow-api-key
SILICONFLOW_BASE_URL=https://api.siliconflow.cn

# ================================
# WebDAV 白名单扩展
# ================================
# - 仅接受 https 协议
# - 可使用英文逗号或换行分隔多个端点
# WHITE_WEBDAV_ENDPOINTS=https://dav.example.com/dav/,https://cloud.example.com/webdav/
WHITE_WEBDAV_ENDPOINTS=
